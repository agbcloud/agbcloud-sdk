{
    "name": "agbcloud-sdk",
    "version": "0.11.0",
    "description": "AGB TypeScript SDK",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "test": "jest",
        "test:unit": "jest --testPathPattern=tests/unit",
        "test:integration": "jest --testPathPattern=tests/integration",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "docs:generate": "node scripts/generate_api_docs.js"
    },
    "keywords": [
        "agb",
        "sdk",
        "typescript"
    ],
    "license": "Apache-2.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "axios": "^1.7.0",
        "dotenv": "^16.4.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.0.0",
        "eslint": "^8.0.0",
        "jest": "^29.0.0",
        "js-yaml": "^4.1.0",
        "prettier": "^3.0.0",
        "ts-jest": "^29.0.0",
        "tsup": "^8.0.0",
        "typedoc": "^0.25.0",
        "typedoc-plugin-markdown": "^3.16.0",
        "typescript": "^5.4.0"
    },
    "optionalDependencies": {
        "playwright": "^1.55.0"
    }
}